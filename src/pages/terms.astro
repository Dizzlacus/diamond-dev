---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Terms & Conditions — Diamond Web Dev"
  description="Website design and development terms and conditions for Diamond Web Dev covering project scope, payments, hosting, maintenance, SEO, and liability."
  stickyNav={false}
>
  <main class="max-w-screen-md mx-auto px-5 md:px-8 py-16 lg:py-24">
    <div class="mb-12">
      <h1 class="font-display text-4xl font-bold text-white leading-[1.2] tracking-tight mb-4">
        Terms & Conditions
      </h1>
      <p class="text-white/45 text-sm">Effective Date: 21 July 2026</p>
    </div>

    <div class="mb-10">
      <p class="text-lg text-white/70 leading-relaxed">
        These Terms & Conditions apply to all website design, development and related digital
        services provided by Diamond Web Dev ("the Developer") to the client ("the Client").
      </p>
    </div>

    <div class="flex flex-col gap-10">
      <section>
        <h2 class="font-display text-xl font-semibold text-white mb-3 tracking-tight">
          1. Services
        </h2>
        <p class="text-base text-white/70 leading-relaxed">
          The Developer agrees to provide the services outlined within the accepted quotation or
          proposal.
        </p>
        <p class="text-base text-white/70 leading-relaxed mt-3">
          Only the services specifically listed within the quotation are included.
        </p>
        <p class="text-base text-white/70 leading-relaxed mt-3">
          Any work outside the agreed scope may be quoted separately before work begins.
        </p>
      </section>

      <section>
        <h2 class="font-display text-xl font-semibold text-white mb-3 tracking-tight">
          2. Project Scope
        </h2>
        <p class="text-base text-white/70 leading-relaxed mb-4">
          The quotation defines the agreed scope of the project. Requests including, but not
          limited to:
        </p>
        <ul class="flex flex-col gap-3">
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Additional pages</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">New functionality</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Booking systems</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Ecommerce</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Membership areas</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Third-party integrations</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Additional revisions</span>
          </li>
        </ul>
        <p class="text-base text-white/70 leading-relaxed mt-4">may be charged separately.</p>
      </section>

      <section>
        <h2 class="font-display text-xl font-semibold text-white mb-3 tracking-tight">
          3. Project Timeline
        </h2>
        <p class="text-base text-white/70 leading-relaxed">
          Estimated completion dates are provided in good faith.
        </p>
        <p class="text-base text-white/70 leading-relaxed mt-3">
          Delays caused by the Client, including failure to provide content, approvals or feedback,
          may extend the project timeline.
        </p>
        <p class="text-base text-white/70 leading-relaxed mt-3">
          The Developer is not liable for delays outside their reasonable control.
        </p>
      </section>

      <section>
        <h2 class="font-display text-xl font-semibold text-white mb-3 tracking-tight">
          4. Client Responsibilities
        </h2>
        <p class="text-base text-white/70 leading-relaxed mb-4">The Client agrees to provide:</p>
        <ul class="flex flex-col gap-3">
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Logos</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Images</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Written content</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Branding</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed"
              >Access credentials (where required)</span
            >
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed"
              >Feedback within a reasonable timeframe</span
            >
          </li>
        </ul>
        <p class="text-base text-white/70 leading-relaxed mt-4">
          The Client is responsible for ensuring all supplied content is accurate and legally owned
          or licensed.
        </p>
      </section>

      <section>
        <h2 class="font-display text-xl font-semibold text-white mb-3 tracking-tight">
          5. Revisions
        </h2>
        <p class="text-base text-white/70 leading-relaxed">
          Unless otherwise agreed in writing:
          <strong class="text-white font-semibold">Two rounds of revisions</strong> are included.
        </p>
        <p class="text-base text-white/70 leading-relaxed mt-3">
          Further revisions or changes after approval may be charged at the Developer's current
          hourly rate.
        </p>
      </section>

      <section>
        <h2 class="font-display text-xl font-semibold text-white mb-3 tracking-tight">
          6. Payment Terms
        </h2>
        <ul class="flex flex-col gap-3">
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">
              A non-refundable deposit of
              <strong class="text-white font-semibold">50%</strong> is required before work
              commences.
            </span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">
              The remaining balance is payable before the website is made live or ownership is
              transferred.
            </span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">
              Invoices are payable within
              <strong class="text-white font-semibold">14 days</strong> unless otherwise agreed.
            </span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">
              Late payments may result in work being paused.
            </span>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="font-display text-xl font-semibold text-white mb-3 tracking-tight">
          7. Cancellation
        </h2>
        <p class="text-base text-white/70 leading-relaxed mb-4">
          If the Client cancels the project after work has commenced:
        </p>
        <ul class="flex flex-col gap-3">
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed"
              >The initial deposit remains non-refundable.</span
            >
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed"
              >Any completed work beyond the deposit value will be invoiced.</span
            >
          </li>
        </ul>
      </section>

      <section>
        <h2 class="font-display text-xl font-semibold text-white mb-3 tracking-tight">
          8. Ownership
        </h2>
        <p class="text-base text-white/70 leading-relaxed">
          Ownership of the completed website transfers to the Client only after full payment has
          been received.
        </p>
        <p class="text-base text-white/70 leading-relaxed mt-3">
          Until full payment is made, all work remains the intellectual property of the Developer.
        </p>
      </section>

      <section>
        <h2 class="font-display text-xl font-semibold text-white mb-3 tracking-tight">
          9. Portfolio Rights
        </h2>
        <p class="text-base text-white/70 leading-relaxed">
          The Developer reserves the right to display completed work within their portfolio,
          website, social media and marketing materials unless otherwise agreed in writing.
        </p>
      </section>

      <section>
        <h2 class="font-display text-xl font-semibold text-white mb-3 tracking-tight">
          10. Hosting
        </h2>
        <p class="text-base text-white/70 leading-relaxed mb-4">
          Where hosting is provided by the Developer:
        </p>
        <ul class="flex flex-col gap-3">
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed"
              >Reasonable efforts will be made to ensure website availability.</span
            >
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed"
              >Continuous uptime cannot be guaranteed.</span
            >
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed"
              >The Developer is not responsible for outages caused by hosting providers, internet
              failures or third-party services.</span
            >
          </li>
        </ul>
      </section>

      <section>
        <h2 class="font-display text-xl font-semibold text-white mb-3 tracking-tight">
          11. Maintenance Plans
        </h2>
        <p class="text-base text-white/70 leading-relaxed">
          Maintenance plans cover only the services specifically included within the selected
          package.
        </p>
        <p class="text-base text-white/70 leading-relaxed mt-3 mb-4">Maintenance does not include:</p>
        <ul class="flex flex-col gap-3">
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">New pages</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Redesigns</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">New functionality</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed"
              >Third-party software configuration</span
            >
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Major content updates</span>
          </li>
        </ul>
        <p class="text-base text-white/70 leading-relaxed mt-4">
          Such work may be quoted separately.
        </p>
      </section>

      <section>
        <h2 class="font-display text-xl font-semibold text-white mb-3 tracking-tight">
          12. Static Website Platform
        </h2>
        <p class="text-base text-white/70 leading-relaxed">
          Unless otherwise stated, websites are delivered using a modern static website
          architecture.
        </p>
        <p class="text-base text-white/70 leading-relaxed mt-3 mb-4">Requests involving:</p>
        <ul class="flex flex-col gap-3">
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Databases</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">User accounts</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Custom dashboards</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Ecommerce</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Dynamic applications</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed"
              >Complex server-side functionality</span
            >
          </li>
        </ul>
        <p class="text-base text-white/70 leading-relaxed mt-4">
          are outside the original project scope and may require an additional quotation.
        </p>
      </section>

      <section>
        <h2 class="font-display text-xl font-semibold text-white mb-3 tracking-tight">
          13. Third-Party Services
        </h2>
        <p class="text-base text-white/70 leading-relaxed mb-4">
          Projects may include or integrate with third-party services including, but not limited
          to:
        </p>
        <ul class="flex flex-col gap-3">
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Cloudflare</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">GitHub</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Google Maps</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Google Analytics</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Booking systems</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Payment providers</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Email services</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Headless CMS platforms</span>
          </li>
        </ul>
        <p class="text-base text-white/70 leading-relaxed mt-4 mb-4">
          The Developer accepts no responsibility for:
        </p>
        <ul class="flex flex-col gap-3">
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Service outages</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">API changes</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Pricing changes</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Product discontinuation</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Security incidents</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed"
              >Changes made by third-party providers</span
            >
          </li>
        </ul>
      </section>

      <section>
        <h2 class="font-display text-xl font-semibold text-white mb-3 tracking-tight">
          14. Search Engine Optimisation
        </h2>
        <p class="text-base text-white/70 leading-relaxed">
          The Developer follows recognised technical SEO best practices where included.
        </p>
        <p class="text-base text-white/70 leading-relaxed mt-3 mb-4">
          However, no guarantee is made regarding:
        </p>
        <ul class="flex flex-col gap-3">
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Google rankings</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Search engine placement</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Website traffic</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Lead generation</span>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="font-display text-xl font-semibold text-white mb-3 tracking-tight">
          15. Browser Compatibility
        </h2>
        <p class="text-base text-white/70 leading-relaxed">
          Websites are designed to support the latest major versions of commonly used browsers.
        </p>
        <p class="text-base text-white/70 leading-relaxed mt-3">
          Compatibility with outdated browsers is not guaranteed.
        </p>
      </section>

      <section>
        <h2 class="font-display text-xl font-semibold text-white mb-3 tracking-tight">
          16. Warranty
        </h2>
        <p class="text-base text-white/70 leading-relaxed">
          The Developer will correct bugs relating to the original agreed specification reported
          within <strong class="text-white font-semibold">30 days</strong> of launch at no
          additional charge.
        </p>
        <p class="text-base text-white/70 leading-relaxed mt-3 mb-4">This warranty excludes:</p>
        <ul class="flex flex-col gap-3">
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Client modifications</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Third-party integrations</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Browser updates</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Hosting issues</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed"
              >Changes requested after launch</span
            >
          </li>
        </ul>
      </section>

      <section>
        <h2 class="font-display text-xl font-semibold text-white mb-3 tracking-tight">
          17. Client Changes After Launch
        </h2>
        <p class="text-base text-white/70 leading-relaxed">
          Any changes requested after website launch will be treated as additional work unless
          covered by an active maintenance agreement.
        </p>
        <p class="text-base text-white/70 leading-relaxed mt-3">
          Work is billed at the Developer's current hourly rate or agreed fixed fee.
        </p>
      </section>

      <section>
        <h2 class="font-display text-xl font-semibold text-white mb-3 tracking-tight">
          18. Limitation of Liability
        </h2>
        <p class="text-base text-white/70 leading-relaxed mb-4">
          To the maximum extent permitted by law, the Developer shall not be liable for:
        </p>
        <ul class="flex flex-col gap-3">
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Loss of profits</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
            <span class="text-base text-white/70 leading-relaxed">Loss of revenue</span>
          </li>
          <li class="flex gap-3 items-start">
            <span class="mt-[6px] shrink-0 w-[6px] h-[6px] rounded-full bg-accent"></span>
