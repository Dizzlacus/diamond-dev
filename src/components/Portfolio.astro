<section id="portfolio" class="bg-page reveal">
  <div class="px-5 py-12 md:px-10 md:py-14 lg:px-16 lg:py-24">
    <div class="max-w-7xl mx-auto">
      <div class="max-w-3xl mx-auto text-left md:text-center">
        <p class="section-kicker">Portfolio</p>
        <h2
          class="mt-5 font-display text-4xl font-bold tracking-[-0.04em] text-white md:text-6xl"
        >
          Recent work.
        </h2>
        <p class="mt-5 text-lg leading-8 text-white/55">
          A growing collection of custom websites designed to feel polished, load quickly, and
          support real business goals.
        </p>
      </div>

      <div class="mt-8 flex items-center justify-center gap-3 md:hidden">
        <button
          id="portfolio-prev"
          type="button"
          class="flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/[0.03] text-white/70 transition-colors hover:border-accent/50 hover:text-accent"
          aria-label="Previous portfolio item"
        >
          <svg
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19 8 12l7-7"></path>
          </svg>
        </button>
        <button
          id="portfolio-next"
          type="button"
          class="flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/[0.03] text-white/70 transition-colors hover:border-accent/50 hover:text-accent"
          aria-label="Next portfolio item"
        >
          <svg
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="m9 5 7 7-7 7"></path>
          </svg>
        </button>
      </div>

      <div
        id="portfolio-track"
        class="no-scrollbar mt-12 flex snap-x snap-mandatory gap-5 overflow-x-auto scroll-smooth pb-2 md:grid md:overflow-visible md:pb-0 md:grid-cols-2 lg:grid-cols-3"
        aria-label="Portfolio carousel"
      >
        <a
          href="https://dizzlacus.github.io/kings-chair/"
          target="_blank"
          rel="noopener noreferrer"
          class="glass-card hover-glow group min-w-[82vw] snap-start overflow-hidden rounded-[1.5rem] sm:min-w-[420px] md:min-w-0"
        >
          <div class="relative aspect-[4/3] overflow-hidden">
            <img
              src="/img/kings-chair-portfolio.png"
              alt="King's Chair hairdressing salon website"
              class="h-full w-full object-cover object-[center_15%] transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-page/75 via-transparent to-transparent"
              aria-hidden="true"></div>
          </div>

          <div class="p-6">
            <div
              class="inline-flex rounded-full border border-accent/25 bg-accent/10 px-3 py-1.5 text-xs font-semibold text-accent"
            >
              Live Project
            </div>
            <h3 class="mt-5 font-display text-2xl font-bold tracking-[-0.03em] text-white"
              >King's Chair</h3
            >
            <p class="mt-3 text-sm leading-6 text-white/50">
              A Newcastle hairdressing salon site with a bold gallery showcasing the team's
              cutting, colour, and styling work.
            </p>

            <div class="mt-6 flex flex-wrap items-center gap-2">
              <span
                class="rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5 text-xs text-white/60"
                >Custom Build</span
              >
              <span
                class="rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5 text-xs text-white/60"
                >Gallery</span
              >
            </div>

            <div class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-accent">
              <span>View Website</span>
              <svg
                class="h-4 w-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 17 17 7M9 7h8v8"
                ></path>
              </svg>
            </div>
          </div>
        </a>
        <a
          href="https://celesteyoga.co.uk/"
          target="_blank"
          rel="noopener noreferrer"
          class="glass-card hover-glow group min-w-[82vw] snap-start overflow-hidden rounded-[1.5rem] sm:min-w-[420px] md:min-w-0"
        >
          <div class="relative aspect-[4/3] overflow-hidden">
            <img
              src="/img/celeste-yoga-portfolio.png"
              alt="Celeste Yoga website project"
              class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
              decoding="async"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-page/75 via-transparent to-transparent"
              aria-hidden="true"></div>
          </div>

          <div class="p-6">
            <div
              class="inline-flex rounded-full border border-accent/25 bg-accent/10 px-3 py-1.5 text-xs font-semibold text-accent"
            >
              Live Project
            </div>
            <h3 class="mt-5 font-display text-2xl font-bold tracking-[-0.03em] text-white"
              >Celeste Yoga</h3
            >
            <p class="mt-3 text-sm leading-6 text-white/50">
              A calm yoga teacher website for classes, schedules, teacher information, and
              enquiries.
            </p>

            <div class="mt-6 flex flex-wrap items-center gap-2">
              <span
                class="rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5 text-xs text-white/60"
                >Custom Build</span
              >
              <span
                class="rounded-full border border-white/10 bg-white/[0.03] px-3 py-1.5 text-xs text-white/60"
                >Responsive</span
              >
            </div>

            <div class="mt-6 inline-flex items-center gap-2 text-sm font-bold text-accent">
              <span>View Website</span>
              <svg
                class="h-4 w-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M7 17 17 7M9 7h8v8"
                ></path>
              </svg>
            </div>
          </div>
        </a>
      </div>

      <div
        id="portfolio-dots"
        class="mt-8 flex justify-center gap-2 md:hidden"
        aria-label="Choose portfolio item"
      >
        <button
          type="button"
          class="h-2.5 w-8 rounded-full bg-accent"
          aria-label="Show portfolio item 1"
          data-portfolio-index="0"></button>
        <button
          type="button"
          class="h-2.5 w-2.5 rounded-full bg-white/20"
          aria-label="Show portfolio item 2"
          data-portfolio-index="1"></button>
      </div>
    </div>
  </div>
</section>
